{
  "$schema": "https://opencode.ai/config.json",
 "plugin": [
    "opencode-google-antigravity-auth"
  ],
  "mcp": {
    "tavily-mcp": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "enabled": true
    },
    "downsub-mcp": {
      "type": "remote",
      "url": "https://downsub.aurensoft.me/mcp?apiKey={env:DOWNSUB_API_KEY}",
      "enabled": true
    }
  }
}
