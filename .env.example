# ─── down-sub-mcp Server ─────────────────────────────────────────
# API Key — MCP'ye erisim icin Bearer token
# Guvenli bir token uretin: openssl rand -hex 32
API_KEY=your-secret-api-key-here

# Server port (varsayilan: 3000)
PORT=3000

# Node environment
NODE_ENV=production

# ─── OpenCode MCP Clients ────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key
DOWNSUB_API_KEY=your-downsub-api-key
